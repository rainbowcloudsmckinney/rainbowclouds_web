# Environment Variables
# Copy this file to .env.local and fill in your Stripe keys

# Get your keys from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
# Use live keys (sk_live_...) for production

STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# CORS - Set this in production to your actual domain
# Examples: https://rainbowclouds.vercel.app or https://www.rainbowclouds.com
# Leave blank for development (defaults to * for local testing)
ALLOWED_ORIGIN=
